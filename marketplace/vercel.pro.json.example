{
  "_note": "Hobby mode: hourly cron is disabled in vercel.json. When you upgrade to Vercel Pro, rename this file to vercel.json. The Hobby daily SLA cron can be removed entirely if not needed.",
  "crons": [
    {
      "path": "/api/admin/sla-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/grant-monthly-credits",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/admin/update-loyalty-levels",
      "schedule": "0 2 * * *"
    }
  ]
}

{
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "framer-motion": "^12.34.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "scripts": {
    "check:english": "node scripts/check-english-only.mjs",
    "check:pr-guardrails": "node scripts/check-pr-guardrails.mjs",
    "check:prepublic-security": "node scripts/pre-public-security-check.mjs",
    "check:status-drift": "node scripts/check-status-drift.mjs",
    "preflight": "node scripts/preflight.mjs",
    "health-check": "node scripts/health-check.mjs",
    "dev": "next dev",
    "dev:checked": "npm run check:english && npm run preflight && next dev",
    "build": "npm run check:english && next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "npm run check:english && tsc --noEmit",
    "lint:eslint": "next lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.config.ts tests/unit",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:visual:lighthouse": "echo 'Run Lighthouse via .github/workflows/lighthouse.yml'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --max-warnings=50"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "msw": "^2.12.10",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.6",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_PLATFORM_BASE_URL=http://localhost:3000

# Stripe — payments & Connect
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Google Analytics 4 (optional — omit to disable tracking)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry — error tracking & performance monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend — transactional email
RESEND_API_KEY=
# Dev only: redirect all emails to this address instead of real recipient
DEV_EMAIL_OVERRIDE=

# Groq — AI provider (free tier, OpenAI-compatible)
# Required for AI job description writer + alert suggestions
GROQ_API_KEY=

# AI model overrides (optional — defaults in lib/ai/config.ts)
# AI_MODEL_JOB_DESC=llama-3.3-70b-versatile
# AI_MODEL_ALERTS=llama-3.1-8b-instant

# Anthropic — legacy (kept for health check; not used by AI routes)
ANTHROPIC_API_KEY=

# Upstash Redis — distributed rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Webhook secret encryption (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET_ENCRYPTION_KEY=

# Live services master switch (set true in production only)
LIVE_SERVICES_ENABLED=false

# Per-service dev overrides (test one service at a time, never commit as true)
EMAIL_SEND_ENABLED=false
AI_CALLS_ENABLED=false

# Guest jobs — email verification guard
REQUIRE_GUEST_EMAIL_VERIFICATION=true

# Task alerts — cron secret
TASK_ALERT_SECRET=

# Address lookup — Eircode validation
# Set ADDRESS_PROVIDER=ideal_postcodes to enable live address lookup (requires API key)
# Leave as 'none' (or omit) for format-only Eircode validation — no API key needed
ADDRESS_PROVIDER=none
# Get API key from: ideal-postcodes.co.uk → Dashboard
IDEAL_POSTCODES_API_KEY=

# ─── Cloudflare Integrations ──────────────────────────────────

# Cloudflare Turnstile — bot protection (dash.cloudflare.com → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare Web Analytics — privacy-first, cookie-free analytics
# Get token from dash.cloudflare.com → Analytics & Logs → Web Analytics
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Cloudflare R2 — S3-compatible object storage for uploads
# Requires: npm install @aws-sdk/client-s3 @aws-sdk/s3-request-presigner
# Dashboard: dash.cloudflare.com → R2 Object Storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=workmate-uploads
CLOUDFLARE_R2_PUBLIC_URL=

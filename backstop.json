{
  "id": "workmate",
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 900 },
    { "name": "tablet", "width": 768, "height": 1024 },
    { "name": "mobile", "width": 375, "height": 812 }
  ],
  "scenarios": [
    {
      "label": "Homepage",
      "url": "http://localhost:3001/en",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    },
    {
      "label": "Search",
      "url": "http://localhost:3001/en/search",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    },
    {
      "label": "Providers",
      "url": "http://localhost:3001/en/providers",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    },
    {
      "label": "Login",
      "url": "http://localhost:3001/en/login",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    },
    {
      "label": "Register",
      "url": "http://localhost:3001/en/register",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    },
    {
      "label": "Post Job",
      "url": "http://localhost:3001/en/post-job",
      "delay": 500,
      "misMatchThreshold": 0.01,
      "requireSameDimensions": false,
      "hideSelectors": [
        ".sonner-toast-bar",
        "[data-testid='cookie-banner']",
        "time",
        "[data-time]"
      ],
      "postInteractionWait": 300
    }
  ],
  "paths": {
    "bitmaps_reference": "backstop_data/bitmaps_reference",
    "bitmaps_test": "backstop_data/bitmaps_test",
    "html_report": "backstop_data/html_report",
    "ci_report": "backstop_data/ci_report"
  },
  "report": ["browser", "CI"],
  "engine": "playwright",
  "engineOptions": {
    "browser": "chromium",
    "args": ["--no-sandbox", "--disable-setuid-sandbox"]
  },
  "asyncCaptureLimit": 3,
  "asyncCompareLimit": 50,
  "debug": false,
  "debugWindow": false
}
